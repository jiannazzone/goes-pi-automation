# SatDump live-decode parameters -- installed to /etc/goes-monitor/decode.env (root:root 0600).
# Confirmed on device: pipeline goes_hrit, output /home/aiannazzone/SatDump,
# HRIT @ 1694.1 MHz, SatDump v1.2.2 `satdump live`. Samplerate 2.4e6 (RTL-SDR
# ceiling; the pipeline's 6e6 default is an Airspy value the RTL cannot reach).
PIPELINE=goes_hrit
OUTPUT_DIR=/home/aiannazzone/SatDump
FREQUENCY=1694.1e6
SAMPLERATE=2.4e6
# >>> SET THIS: the tuner gain that produced your working ~6 dB decode (RTL-SDR
#     range ~0-49). The service refuses to start until this is a real value.
#     Confirm the exact flag name against `satdump live goes_hrit` once the
#     dongle is connected -- rtlsdr exposes it as --gain in this build.
GAIN=__SET_WORKING_GAIN__
# LNA is powered from the dongle -> bias tee on. Set to empty to disable.
BIAS_FLAG=--bias
HTTP_SERVER=127.0.0.1:8080
