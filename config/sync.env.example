# Archive sync target -- installed to /etc/goes-monitor/sync.env (root:root 0600).
# Transport is SSH over Tailscale. The sync script self-skips while these are
# placeholders, so the timer stays quiet until you fill them in.
#
# NOTE: systemd EnvironmentFile does NOT support inline (# ...) comments on a
# value line -- keep values bare, put notes on their own comment lines.
#
# ARCHIVE_HOST: Tailscale name of the chosen archive host, media-center (100.74.1.50).
# ARCHIVE_DEST: destination dir on the archive, e.g. /mnt/hdd/goes19 (must exist).
OUTPUT_DIR=/home/aiannazzone/SatDump
ARCHIVE_HOST=media-center
ARCHIVE_USER=REPLACE_ME_ARCHIVE_USER
ARCHIVE_DEST=REPLACE_ME_DEST_PATH
SSH_KEY=/home/aiannazzone/.ssh/goes_archive_ed25519
