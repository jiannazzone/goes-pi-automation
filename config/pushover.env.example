# Pushover credentials -- installed to /etc/goes-monitor/pushover.env (root:root 0600).
# Used by both the health monitor and the disk guard. Never commit real values.
PUSHOVER_TOKEN=REPLACE_ME_APP_TOKEN
PUSHOVER_USER=REPLACE_ME_USER_KEY
# Priority 0 = normal (respects quiet hours), per the design brief.
PUSHOVER_PRIORITY=0
